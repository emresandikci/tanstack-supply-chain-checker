{
  "name": "@emstack/tanstack-supply-chain-checker",
  "version": "1.2.0",
  "description": "Detect and fix the mini-shai-hulud TanStack supply-chain attack (socket.dev/blog/tanstack-npm-packages-compromised-mini-shai-hulud-supply-chain-attack)",
  "type": "module",
  "bin": {
    "tanstack-supply-chain-checker": "./dist/cli.js"
  },
  "bugs": {
    "url": "https://github.com/emresandikci/tanstack-supply-chain-checker/issues"
  },
  "homepage": "https://github.com/emresandikci/tanstack-supply-chain-checker#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emresandikci/tanstack-supply-chain-checker.git"
  },
  "files": [
    "dist",
    "data",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build src/cli.ts --outfile dist/cli.js --target node --banner '#!/usr/bin/env node'",
    "dev": "bun run src/cli.ts",
    "validate": "bun run test/validate.ts",
    "prepublishOnly": "bun run build && bun run validate"
  },
  "keywords": [
    "security",
    "supply-chain",
    "tanstack",
    "npm-audit"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@clack/prompts": "^1.4.0"
  }
}
